#!/usr/bin/env python3
"""
hermes-tenant — управление tenant-пользователями Hermes.
v1.0 — авто-онбординг, офбординг, список.

Usage:
  hermes-tenant onboard @username [--tg-id=ID] [--name=NAME]
  hermes-tenant offboard @username
  hermes-tenant list
  hermes-tenant onboard --tg-id=319665243 --name=poliakarm  # админ (skip Linux user)
"""

import argparse
import grp
import json
import os
import pwd
import shutil
import subprocess
import sys
import time
from pathlib import Path
from typing import Optional, Tuple

HERMES_HOME = Path(os.environ.get("HERMES_HOME", os.path.expanduser("~/.hermes")))
CONFIG_YAML = HERMES_HOME / "config.yaml"
PROFILES_DIR = HERMES_HOME / "profiles"
SHARED_SKILLS = Path("/opt/hermes/shared-skills")
DEFAULT_ENV_TEMPLATE = """# Tenant .env — только TELEGRAM_BOT_TOKEN
# Зашифровано через age. Приватный ключ: ~/.hermes/keys/hermes.key
TELEGRAM_BOT_TOKEN={bot_token}
"""

PROFILE_CONFIG_TEMPLATE = """# Hermes profile: {name} (tg={tg_id})
# Auto-generated by hermes-tenant onboard v1.0

model:
  base_url: https://api.deepseek.com/v1
  default: deepseek-v4-pro
  provider: custom

agent:
  max_turns: 100
  gateway_timeout: 1200
  disabled_toolsets:
    - delegation
    - code_execution

profile:
  role: user
  shared_skills: /opt/hermes/shared-skills
  instincts: {hermes_home}/instincts
  sandbox: {sandbox}
  tenant_name: {name}

obsidian:
  vault_path: {sandbox}/obsidian-vault
"""

CHANNEL_PROMPT_TEMPLATE = """Ты Hermes — AI-ассистент {name}.

## ТВОЁ ОКРУЖЕНИЕ
- Песочница: {sandbox} (твоя рабочая директория)
- Там ты можешь создавать проекты, скрипты, файлы
- Запускай код через терминал — это твоя изолированная среда

## ЧТО ТЫ МОЖЕШЬ
- Писать скрипты и программы
- Работать с API (свой ключ в .env)
- Писать свои торговые мониторы (со своим API-ключом)
- Использовать общие скиллы из /opt/hermes/shared-skills/
- Искать в интернете, анализировать данные
- Создавать свои проекты в {sandbox}projects/
- Ставить cron-задачи (свои, в своей песочнице)

## ОГРАНИЧЕНИЯ
- Не читай /home/openclaw/ и /home/hermes-*/ — это чужие песочницы
- Торговые скиллы (bybit-trading и др.) недоступны — используй свой API-ключ

## СТИЛЬ
- Дружелюбный, полезный
- На русском, кратко, по делу"""


def load_yaml(path: Path) -> dict:
    """Load YAML config, return empty dict if missing."""
    try:
        import yaml
        with open(path) as f:
            return yaml.safe_load(f) or {}
    except FileNotFoundError:
        return {}
    except ImportError:
        print("❌ PyYAML не установлен: pip install pyyaml", file=sys.stderr)
        sys.exit(1)


def save_yaml(path: Path, data: dict):
    """Save YAML config preserving structure."""
    import yaml
    with open(path, "w") as f:
        yaml.safe_dump(data, f, default_flow_style=False, allow_unicode=True, sort_keys=False)


def get_bot_token() -> str:
    """Get TELEGRAM_BOT_TOKEN from env or .env."""
    token = os.environ.get("TELEGRAM_BOT_TOKEN", "")
    if token:
        return token
    for path in [HERMES_HOME / ".env", HERMES_HOME / "profiles" / "poliakarm" / ".env"]:
        if path.exists():
            with open(path) as f:
                for line in f:
                    if line.startswith("TELEGRAM_BOT_TOKEN="):
                        return line.split("=", 1)[1].strip()
    return ""


def encrypt_env(env_path: Path) -> bool:
    """Encrypt .env with age. Returns True on success."""
    key_file = HERMES_HOME / "keys" / "hermes.key"
    if not key_file.exists():
        print(f"⚠️  age key not found at {key_file}, skipping encryption", file=sys.stderr)
        return False
    try:
        pubkey = subprocess.check_output(
            ["grep", "public key", str(key_file)], text=True
        ).strip().split()[-1]
        enc_path = Path(str(env_path) + ".enc")
        subprocess.run(
            ["age", "-r", pubkey, "-o", str(enc_path), str(env_path)],
            check=True, capture_output=True, text=True
        )
        # Set perms
        os.chmod(enc_path, 0o600)
        print(f"   ✅ .env зашифрован: {enc_path}")
        return True
    except Exception as e:
        print(f"   ⚠️  Ошибка шифрования: {e}", file=sys.stderr)
        return False


def setup_iptables(username: str, uid: int) -> bool:
    """Добавить iptables-правила изоляции для tenant'а.
    Блокирует localhost, разрешает DNS.
    Возвращает True если успешно."""
    rules = [
        ["sudo", "iptables", "-A", "OUTPUT", "-m", "owner", "--uid-owner", str(uid),
         "-d", "127.0.0.0/8", "-j", "DROP"],
        ["sudo", "iptables", "-A", "OUTPUT", "-m", "owner", "--uid-owner", str(uid),
         "-p", "udp", "--dport", "53", "-j", "ACCEPT"],
    ]
    try:
        for rule in rules:
            subprocess.run(rule, check=True, capture_output=True, text=True)
        print(f"   ✅ iptables: изоляция {username} (uid={uid})")
        return True
    except subprocess.CalledProcessError as e:
        print(f"   ⚠️  iptables не добавлены: {e.stderr.strip() if e.stderr else e}", file=sys.stderr)
        print(f"   👉 Ручками: sudo iptables -A OUTPUT -m owner --uid-owner {uid} -d 127.0.0.0/8 -j DROP", file=sys.stderr)
        return False


def remove_iptables(username: str, uid: int) -> bool:
    """Удалить iptables-правила изоляции для tenant'а."""
    rules = [
        ["sudo", "iptables", "-D", "OUTPUT", "-m", "owner", "--uid-owner", str(uid),
         "-d", "127.0.0.0/8", "-j", "DROP"],
        ["sudo", "iptables", "-D", "OUTPUT", "-m", "owner", "--uid-owner", str(uid),
         "-p", "udp", "--dport", "53", "-j", "ACCEPT"],
    ]
    try:
        for rule in rules:
            subprocess.run(rule, check=True, capture_output=True, text=True)
        return True
    except subprocess.CalledProcessError:
        return False


def create_linux_user(name: str, tg_id: str) -> Tuple[bool, str]:
    username = f"hermes-{name}"
    try:
        pwd.getpwnam(username)
        print(f"   ⏭️  Linux-пользователь {username} уже существует")
        return False, username
    except KeyError:
        pass

    subprocess.run(
        ["sudo", "useradd", "-m", "-s", "/bin/bash", username],
        check=True
    )
    sandbox = Path(f"/home/{username}")
    for d in ["projects", "scripts"]:
        (sandbox / d).mkdir(parents=True, exist_ok=True)
    subprocess.run(
        ["sudo", "chown", "-R", f"{username}:{username}", str(sandbox)],
        check=True
    )
    print(f"   ✅ Linux-пользователь создан: {username}")
    return True, username


def create_obsidian_vault(sandbox: str, username: str, name: str):
    """Create per-tenant Obsidian vault."""
    vault = Path(sandbox) / "obsidian-vault"
    vault.mkdir(parents=True, exist_ok=True)
    
    # Welcome note
    welcome = vault / "Добро пожаловать.md"
    welcome.write_text(f"""# Добро пожаловать, {name}!

Это твой личный Obsidian vault для знаний и заметок.

## Твоя песочница
- **Директория:** {sandbox}
- **Проекты:** {sandbox}projects/
- **Скрипты:** {sandbox}scripts/

## Связанные страницы
- [[Инструкция по использованию]]
""", encoding="utf-8")

    instructions = vault / "Инструкция по использованию.md"
    instructions.write_text("""# Инструкция по использованию

Hermes может читать и писать заметки в этом vault через скилл Obsidian.

## Команды
- «Запиши в Obsidian...» — сохранить заметку
- «Найди в Obsidian...» — поиск по vault
- «Прочитай заметку X» — открыть заметку

## Совет
Используй `[[wikilinks]]` для связи заметок — Obsidian строит граф знаний.
""", encoding="utf-8")
    
    subprocess.run(["sudo", "chown", "-R", f"{username}:{username}", str(vault)], check=True)
    print(f"   ✅ Obsidian vault: {vault}")


def update_allowed_users(tg_id: str, action: str = "add"):
    """Add/remove tg_id to/from TELEGRAM_ALLOWED_USERS in ~/.hermes/.env."""
    env_file = HERMES_HOME / ".env"
    if not env_file.exists():
        print(f"   ⚠️  .env not found: {env_file}")
        return
    var_name = "TELEGRAM_" + "ALLOWED_" + "USERS"
    content = env_file.read_text()
    new_lines = []
    for line in content.splitlines():
        if line.startswith(var_name + "=") and not line.strip().startswith("#"):
            prefix = var_name + "="
            existing = line.split("=", 1)[1]
            ids = [x.strip() for x in existing.split(",") if x.strip()]
            if action == "add" and tg_id not in ids:
                ids.append(tg_id)
                print(f"   ✅ {tg_id} added to {var_name}")
            elif action == "remove" and tg_id in ids:
                ids.remove(tg_id)
                print(f"   ✅ {tg_id} removed from {var_name}")
            new_lines.append(f"{prefix}{','.join(ids)}")
        else:
            new_lines.append(line)
    env_file.write_text("\n".join(new_lines) + "\n")
    os.chmod(env_file, 0o600)


def onboard(args):
    """Onboard a new tenant user."""
    tg_id = args.tg_id
    name = args.name

    if not tg_id or not name:
        print("❌ Укажи --tg-id и --name", file=sys.stderr)
        print("   hermes-tenant onboard --tg-id=123456789 --name=ilya", file=sys.stderr)
        sys.exit(1)

    sandbox = f"/home/hermes-{name}"
    profile_name = f"user_{tg_id}"
    profile_dir = PROFILES_DIR / profile_name

    # Проверка дубликата
    if profile_dir.exists():
        print(f"❌ Профиль {profile_name} уже существует!", file=sys.stderr)
        print(f"   👉 Для пересоздания: hermes-tenant offboard --tg-id={tg_id} сначала", file=sys.stderr)
        sys.exit(1)

    print(f"\n🚀 Онбординг: {name} (tg={tg_id})")
    print(f"   Песочница: {sandbox}")
    print(f"   Профиль: {profile_name}\n")

    # 1. Linux user
    created, username = create_linux_user(name, tg_id)
    sandbox = f"/home/{username}"

    # 1a. iptables isolation
    try:
        uid = pwd.getpwnam(username).pw_uid
        setup_iptables(username, uid)
    except KeyError:
        pass

    # 2. Hermes profile
    profile_dir.mkdir(parents=True, exist_ok=True)
    (profile_dir / "memory").mkdir(exist_ok=True)

    # Config
    config = PROFILE_CONFIG_TEMPLATE.format(
        name=name, tg_id=tg_id, sandbox=sandbox,
        hermes_home=str(HERMES_HOME)
    )
    (profile_dir / "config.yaml").write_text(config)
    print(f"   ✅ config.yaml создан")

    # .env
    bot_token = get_bot_token()
    env_content = DEFAULT_ENV_TEMPLATE.format(bot_token=bot_token)
    env_path = profile_dir / ".env"
    env_path.write_text(env_content)
    os.chmod(env_path, 0o600)
    print(f"   ✅ .env создан (chmod 600)")

    # Encrypt .env
    encrypt_env(env_path)

    # 3. Main config — channel_prompts + channel_profiles
    cfg = load_yaml(CONFIG_YAML)
    tg = cfg.setdefault("telegram", {})
    
    prompts = tg.setdefault("channel_prompts", {})
    prompt = CHANNEL_PROMPT_TEMPLATE.format(name=name, sandbox=sandbox)
    prompts[tg_id] = prompt
    
    profiles_map = tg.setdefault("channel_profiles", {})
    profiles_map[tg_id] = profile_name

    save_yaml(CONFIG_YAML, cfg)
    print(f"   ✅ channel_prompt + profile добавлены в config.yaml")

    # 3a. TELEGRAM_ALLOWED_USERS — without this gateway sends "Unauthorized user"
    update_allowed_users(tg_id, action="add")

    # 4. Obsidian vault (#5 — per-tenant isolation)
    create_obsidian_vault(sandbox, username, name)

    # 5. Set up permissions for Hermes process to write to sandbox
    try:
        hermes_user = os.environ.get("USER", "openclaw")
        subprocess.run(
            ["sudo", "chown", f"{username}:{hermes_user}", sandbox],
            check=True, capture_output=True
        )
        subprocess.run(
            ["sudo", "chmod", "770", sandbox],
            check=True, capture_output=True
        )
        print(f"   ✅ Права на песочницу: {username}:{hermes_user} 770")
    except Exception as e:
        print(f"   ⚠️  Не удалось выставить права: {e}")
        print(f"   👉 Ручками: sudo chown {username}:openclaw {sandbox} && sudo chmod 770 {sandbox}")

    print(f"\n✅ Онбординг завершён!")
    print(f"   Пользователь пусть пишет /start боту, потом /new для сброса сессии.")
    print(f"   Тест: «Создай файл test.txt в песочнице» → {sandbox}/test.txt")


def offboard(args):
    """Remove a tenant user."""
    tg_id = args.tg_id
    if not tg_id:
        print("❌ Укажи --tg-id", file=sys.stderr)
        sys.exit(1)

    profile_name = f"user_{tg_id}"
    profile_dir = PROFILES_DIR / profile_name

    if not profile_dir.exists():
        print(f"❌ Профиль {profile_name} не найден", file=sys.stderr)
        sys.exit(1)

    # Find username from config
    cfg = load_yaml(profile_dir / "config.yaml")
    tenant_name = cfg.get("profile", {}).get("tenant_name", "")
    sandbox = cfg.get("profile", {}).get("sandbox", "")
    username = f"hermes-{tenant_name}" if tenant_name else ""

    print(f"\n🗑️  Офбординг: {tenant_name} (tg={tg_id})")

    # 1. Remove from main config
    main_cfg = load_yaml(CONFIG_YAML)
    tg = main_cfg.get("telegram", {})
    prompts = tg.get("channel_prompts", {})
    profiles_map = tg.get("channel_profiles", {})
    
    prompts.pop(tg_id, None)
    profiles_map.pop(tg_id, None)
    save_yaml(CONFIG_YAML, main_cfg)
    print(f"   ✅ Удалён из channel_prompts + channel_profiles")

    # Also remove from TELEGRAM_ALLOWED_USERS
    update_allowed_users(tg_id, action="remove")

    # 2. Backup profile
    backup_dir = HERMES_HOME / "backups" / "offboarded"
    backup_dir.mkdir(parents=True, exist_ok=True)
    backup_path = backup_dir / f"user_{tg_id}_{time.strftime('%Y%m%d_%H%M')}.tar.gz"
    subprocess.run(
        ["tar", "czf", str(backup_path), "-C", str(PROFILES_DIR), profile_name],
        check=True
    )
    print(f"   ✅ Бэкап профиля: {backup_path}")

    # 3. Remove profile
    shutil.rmtree(profile_dir)
    print(f"   ✅ Профиль удалён")

    # 4. Remove iptables + linux user
    if username:
        try:
            uid = pwd.getpwnam(username).pw_uid
            removed = remove_iptables(username, uid)
            if removed:
                print(f"   ✅ iptables-правила удалены (uid={uid})")
            else:
                print(f"   ⏭️  iptables-правила не найдены (uid={uid})")
        except KeyError:
            print(f"   ⏭️  Linux-пользователь {username} не найден — iptables пропускаем")

        try:
            pwd.getpwnam(username)
            subprocess.run(["sudo", "userdel", "-r", username], check=True)
            print(f"   ✅ Linux-пользователь {username} удалён")
        except KeyError:
            print(f"   ⏭️  Linux-пользователь {username} не найден")

    print(f"\n✅ Офбординг завершён.")
    print(f"   Не забудь перезапустить gateway: sudo systemctl restart hermes-gateway")


def list_tenants():
    """List all tenant profiles."""
    if not PROFILES_DIR.exists():
        print("Нет профилей.")
        return

    cfg = load_yaml(CONFIG_YAML)
    profiles_map = cfg.get("telegram", {}).get("channel_profiles", {})

    print(f"\n📋 Tenant-пользователи ({len(profiles_map)}):\n")
    print(f"{'TG ID':<15} {'Профиль':<22} {'Имя':<15} {'Песочница'}")
    print("-" * 75)

    for tg_id, profile_name in profiles_map.items():
        if profile_name == "poliakarm":
            continue  # skip admin
        profile_dir = PROFILES_DIR / profile_name
        pcfg = load_yaml(profile_dir / "config.yaml") if (profile_dir / "config.yaml").exists() else {}
        name = pcfg.get("profile", {}).get("tenant_name", "?")
        sandbox = pcfg.get("profile", {}).get("sandbox", "?")
        try:
            vault = "✅" if Path(sandbox, "obsidian-vault").exists() else "❌"
        except PermissionError:
            vault = "❓"
        print(f"{tg_id:<15} {profile_name:<22} {name:<15} {sandbox}  vault={vault}")

    print()


def main():
    parser = argparse.ArgumentParser(description="Hermes tenant management")
    sub = parser.add_subparsers(dest="command")

    onboard_p = sub.add_parser("onboard", help="Onboard new tenant")
    onboard_p.add_argument("--tg-id", required=True, help="Telegram user ID")
    onboard_p.add_argument("--name", required=True, help="Short name (e.g. ilya)")

    offboard_p = sub.add_parser("offboard", help="Remove tenant")
    offboard_p.add_argument("--tg-id", required=True, help="Telegram user ID")

    sub.add_parser("list", help="List all tenants")

    args = parser.parse_args()

    if args.command == "onboard":
        onboard(args)
    elif args.command == "offboard":
        offboard(args)
    elif args.command == "list":
        list_tenants()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
